PORT=3000

# Core APIs
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Twilio Voice + WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=whatsapp:+00000000000
WHATSAPP_FALLBACK_URL=https://wa.me/00000000000
DOCTOR_WHATSAPP=whatsapp:+00000000000
DOCTOR_EMAIL=doctor@example.com

# SMTP for doctor email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# n8n brain endpoint
N8N_BRAIN_URL=

# Optional: override default wss://streaming.assemblyai.com/v3/ws (e.g. EU: wss://streaming.eu.assemblyai.com/v3/ws)
# ASSEMBLYAI_STREAMING_URL=

# Optional: AssemblyAI audio chunking (μ-law bytes; defaults 400–8000 = 50ms–1s)
# AAI_MIN_SEND_BYTES=400
# AAI_MAX_SEND_BYTES=8000

# File upload STT test only (/test-stt → Whisper)
STT_MODEL=whisper-1
STT_LANGUAGE=fr

# Runtime behavior
KILL_SWITCH=false
WELCOME_TEXT=Bonjour et bienvenue au cabinet du Dr Crichi a Saint-Cloud. Dites-moi votre question, et je vous aide du mieux possible.
DEGRADED_VOICE_TEXT=Desole, un probleme technique est survenu. Pour continuer, veuillez consulter le lien WhatsApp que je vous envoie maintenant.

# Debug (optional)
# DEBUG_TRANSCRIPT=true
# DEBUG_SAVE_ULAW=true
# DEBUG_SAVE_ULAW_PATH=/tmp/debug_segment.ulaw
